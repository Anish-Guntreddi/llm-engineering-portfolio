# Copy to .env and fill in. The .env is gitignored.

# Postgres + pgvector. Leave UNSET to use the in-memory store (tests / quick local runs).
# With docker-compose (host port 5433):
DOCUQUERY_DATABASE_URL=postgresql://docuquery:docuquery@localhost:5433/docuquery

# Gemini API key (server-side ONLY — never exposed to the frontend).
# Leave UNSET to use the local embedding model + extractive answer fallback.
# DOCUQUERY_GEMINI_API_KEY=your-key-here

# CORS: comma-separated origins for the deployed frontend (add your Vercel domain in prod).
# DOCUQUERY_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Optional overrides
# DOCUQUERY_TOP_K=5
# DOCUQUERY_MIN_SIMILARITY=0.25
# DOCUQUERY_CHUNK_SIZE=900
# DOCUQUERY_CHUNK_OVERLAP=150
